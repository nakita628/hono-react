{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hono-react-tanstack-router-cloudflare",
  "main": "src/index.ts",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist"
  },
  "compatibility_date": "2026-03-01",
  "dev": {
    "ip": "0.0.0.0",
    "port": 8787,
    "local_protocol": "http"
  }
}
